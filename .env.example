# NEOGEN - variables d'environnement (exemple)
# Copier en .env et remplir. Le .env n'est JAMAIS commite (voir .gitignore).

# --- IA par defaut (Anthropic / Claude) ---
# FACULTATIF : si vide, choisis ton IA dans l'interface (GPT, Gemini, DeepSeek,
# Mistral, ou Ollama en local et gratuit). Chaque utilisateur met SA propre cle.
ANTHROPIC_API_KEY=

# --- URL publique du service ---
# Sert aux redirections (ex: retour de paiement). Defaut : http://localhost:8000
# En production, mettre l'URL reelle : https://ton-domaine.com
NEOGEN_BASE_URL=http://localhost:8000

# --- Admin de l'instance ---
# FACULTATIF : email de l'admin (acces aux retours utilisateurs).
# Vide = aucun admin. Mets TON email si tu exploites l'instance.
NEOGEN_ADMIN_EMAIL=

# --- Chemin credentials (avance, facultatif) ---
# Surcharge l'emplacement du fichier credentials/anthropic-api.env.
# NEOGEN_CRED_FILE=/chemin/vers/anthropic-api.env
